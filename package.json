{
  "name": "@arcanea/studio",
  "description": "Arcanea Studio \u2014 multi-model generative surface wired to the Luminor hierarchy. Forked from Open-Generative-AI.",
  "private": true,
  "version": "0.1.0-alpha.0",
  "workspaces": [
    "packages/studio"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:studio": "cd packages/studio && npm run build",
    "setup": "npm install && npm run build:studio",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "electron:build": "vite build && electron-builder --mac",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:all": "vite build && electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "ai.arcanea.studio",
    "productName": "Arcanea Studio",
    "copyright": "Copyright \u00a9 2026 Arcanea",
    "directories": {
      "output": "release"
    },
    "afterPack": "./afterPack.js",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "public/banner.png",
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "public/banner.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "public/banner.png",
      "category": "Utility",
      "maintainer": "Open Generative AI Team",
      "extraFiles": [
        {
          "from": "build/linux/apparmor.profile",
          "to": "resources/apparmor.profile"
        }
      ],
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "axios": "^1.7.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.1",
    "studio": "*",
    "@arcanea/router-spec": "^1.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/vite": "^4.1.18",
    "autoprefixer": "^10.4.24",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.2",
    "vite": "^5.4.0"
  },
  "main": "electron/main.js",
  "author": "Arcanea (Frank Riemer)",
  "homepage": "https://arcanea.ai/studio",
  "repository": {
    "type": "git",
    "url": "https://github.com/frankxai/arcanea-studio"
  }
}